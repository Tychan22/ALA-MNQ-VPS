# ── Telegram ──────────────────────────────────────────────
# Get from @BotFather — create a bot, grab the token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID or channel ID
# DM @userinfobot to get your user ID
TELEGRAM_CHAT_ID=your_chat_id_here

# ── CHART-IMG ─────────────────────────────────────────────
# https://chart-img.com — free tier available
# Leave blank to skip chart screenshots
CHART_IMG_KEY=your_chart_img_key_here

# ── Security (optional) ───────────────────────────────────
# If set, TradingView alerts must include header: X-ALA-Secret: <value>
# Leave blank to disable auth check
WEBHOOK_SECRET=

# ── Server ────────────────────────────────────────────────
# Railway auto-injects PORT — don't set this manually on Railway
# PORT=3000
